<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="worker.css">
    <title>Add New Family</title>
    <link rel="icon" href="/favicon.ico" />
    <script src="https://cdn.jsdelivr.net/npm/tesseract.js@5/dist/tesseract.min.js"></script>
</head>
<body>

<div class="navbar">
    <div class="logo">AASHA Connect</div>
    <nav>
        <a href="dashboard.html">Dashboard</a>
        <a href="add-family.html">Add Family</a>
        <a href="families.html">Families</a>
        <a href="qr.html">Scan QR</a>
        <a href="login.html" class="logout">Logout</a>
    </nav>
</div>

<div class="center-box">
    <h2>Add New Family</h2>

    <!-- STEPPER PROGRESS BAR -->
    <div style="display: flex; justify-content: space-between; margin-bottom: 25px; font-size: 13px; font-weight: bold; position: relative;">
      <div style="flex: 1; text-align: center; border-bottom: 3px solid #ff1675; padding-bottom: 8px; color: #ff1675;" id="step1Indicator">1. Family Basics</div>
      <div style="flex: 1; text-align: center; border-bottom: 3px solid rgba(255,255,255,0.2); padding-bottom: 8px; color: rgba(255,255,255,0.6);" id="step2Indicator">2. Details & Notes</div>
    </div>

    <!-- LANGUAGE SELECT -->
    <select id="voiceLang" class="lang-select">
        <option value="en-IN">English</option>
        <option value="hi-IN">Hindi</option>
        <option value="mr-IN">Marathi</option>
    </select>

    <!-- STEP 1 CONTAINER -->
    <div id="step1Fields">
        <!-- OCR SMART AUTOFILL CONTAINER -->
        <div style="background: rgba(255,255,255,0.1); border-radius: 10px; padding: 15px; margin-bottom: 20px; text-align: left; border: 1px solid rgba(255,255,255,0.1);">
          <span style="font-weight: bold; color: #ffd6eb; font-size: 14px; display: block; margin-bottom: 5px;">📄 Aadhaar Smart Autofill (OCR)</span>
          <p style="font-size: 11px; opacity: 0.8; margin-top: 0; margin-bottom: 12px;">Capture or upload an Aadhaar card to auto-fill details.</p>
          
          <div style="display: flex; gap: 10px; margin-bottom: 10px;">
            <!-- Option A: Camera Capture -->
            <label class="btn" style="flex: 1; text-align: center; font-size: 12px; padding: 10px 5px; background: #ff1675; color: white; cursor: pointer; display: block; margin: 0; border-radius: 30px; font-weight: bold; box-shadow: 0 4px 10px rgba(255, 22, 117, 0.3);">
              📷 Capture Photo
              <input type="file" id="ocrCameraInput" accept="image/*" capture="environment" style="display: none;">
            </label>
            <!-- Option B: Gallery Upload -->
            <label class="btn" style="flex: 1; text-align: center; font-size: 12px; padding: 10px 5px; background: rgba(255,255,255,0.25); color: white; cursor: pointer; display: block; margin: 0; border-radius: 30px; font-weight: bold;">
              🖼️ Upload Image
              <input type="file" id="ocrGalleryInput" accept="image/*" style="display: none;">
            </label>
          </div>
          <div id="ocrStatusText" style="display: none; font-size: 12px; margin-top: 10px; font-weight: bold; color: #ffcc00; text-align: center;">⚙️ Processing card details...</div>
        </div>

        <!-- CONVERSATIONAL VOICE ASSISTANT -->
        <div style="background: rgba(255,255,255,0.1); border-radius: 10px; padding: 15px; margin-bottom: 20px; text-align: left; border: 1px solid rgba(255,255,255,0.1);">
          <span style="font-weight: bold; color: #ffd6eb; font-size: 14px; display: block; margin-bottom: 5px;">🎙️ Conversational Voice Assistant</span>
          <p style="font-size: 11px; opacity: 0.8; margin-top: 0; margin-bottom: 12px;">Speak naturally (e.g. <em>"Name Ramesh Patil, contact 9876543210, address Pune Lane 5"</em>).</p>
          <button type="button" id="voiceAssistantBtn" class="btn" style="width: 100%; box-sizing: border-box; text-align: center; font-size: 13px; padding: 8px; background: #2c7be5; cursor: pointer; border: none; border-radius: 30px;">
            🎤 Dictate Whole Form
          </button>
          <div id="voiceAssistantStatus" style="display: none; font-size: 12px; margin-top: 10px; font-weight: bold; color: #ffcc00; text-align: center;">Listening... speak now</div>
        </div>

        <!-- FAMILY HEAD -->
        <div class="voice-group">
            <input type="text" id="headName" placeholder="Family Head Name *">
            <button onclick="startVoice('headName')">🎤</button>
        </div>

        <!-- CONTACT -->
        <input type="number" id="contact" placeholder="Contact Number *">

        <!-- ABDM ABHA VERIFICATION -->
        <div style="background: rgba(255,255,255,0.1); border-radius: 10px; padding: 15px; margin-bottom: 20px; text-align: left; border: 1px solid rgba(255,255,255,0.1);">
          <span style="font-weight: bold; color: #ffd6eb; font-size: 14px; display: block; margin-bottom: 5px;">🛡️ ABDM ABHA Verification</span>
          <p style="font-size: 11px; opacity: 0.8; margin-top: 0; margin-bottom: 12px;">Link and verify Ayushman Bharat Digital Health Account.</p>
          
          <select id="abhaVerifyMethod" style="padding: 8px; font-size: 13px; margin-bottom: 10px;">
            <option value="aadhaar">Verify via Aadhaar OTP</option>
            <option value="mobile">Verify via Mobile OTP</option>
          </select>
          
          <div style="display: flex; gap: 8px; margin-bottom: 10px;">
            <input type="text" id="abhaVerifyInput" placeholder="Enter Aadhaar or Mobile Number" style="margin-bottom:0; flex: 2; padding: 8px; font-size: 13px;">
            <button type="button" id="abhaSendOtpBtn" class="btn" style="margin: 0; flex: 1; padding: 8px; font-size: 12px; border-radius: 5px; background: #2c7be5; color: white;">Send OTP</button>
          </div>
          
          <div id="abhaOtpSection" style="display: none; margin-bottom: 10px;">
            <p style="font-size: 11px; color: #ffcc00; margin: 5px 0;">Enter OTP (Demo default: 123456)</p>
            <div style="display: flex; gap: 8px;">
              <input type="text" id="abhaOtpInput" placeholder="6-digit OTP" style="margin-bottom:0; flex: 2; padding: 8px; font-size: 13px;">
              <button type="button" id="abhaVerifyOtpBtn" class="btn" style="margin: 0; flex: 1; padding: 8px; font-size: 12px; border-radius: 5px; background: #2cd5c4; color: white;">Verify</button>
            </div>
          </div>
          
          <div id="abhaStatusText" style="display: none; font-size: 12px; margin-top: 10px; font-weight: bold; color: #2cd5c4; text-align: center;"></div>
          
          <!-- Hidden inputs for abhaId and abhaAddress -->
          <input type="hidden" id="abhaId" value="">
          <input type="hidden" id="abhaAddress" value="">
        </div>
        
        <button id="nextStepBtn" class="btn btn-primary" style="margin-top: 10px; width: 100%;">Next Step ➔</button>
    </div>

    <!-- STEP 2 CONTAINER -->
    <div id="step2Fields" style="display: none;">
        <!-- ADDRESS -->
        <div class="voice-group">
            <input type="text" id="address" placeholder="Address *">
            <button onclick="startVoice('address')">🎤</button>
        </div>

        <!-- NOTES -->
        <div class="voice-group">
            <textarea id="notes" placeholder="Family Details (Short Notes)"></textarea>
            <button onclick="startVoice('notes')">🎤</button>
        </div>

        <!-- MEMBERS SECTION -->
        <div style="margin: 20px 0; padding: 15px; background: rgba(255,255,255,0.1); border-radius: 10px; text-align: left;">
            <h4 style="margin-top: 0; color: #ffd6eb; font-size: 15px; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 5px;">👨‍👩‍👧 Family Members</h4>
            
            <div id="membersList" style="margin-bottom: 15px; display: flex; flex-wrap: wrap; gap: 8px;">
                <span style="font-size: 12px; opacity: 0.8;" id="noMembersText">No members added yet</span>
            </div>
            
            <div style="display: flex; gap: 8px; margin-bottom: 8px;">
                <input type="text" id="memberName" placeholder="Member Name" style="margin-bottom:0; flex: 2; padding: 8px; font-size: 13px;">
                <input type="number" id="memberAge" placeholder="Age" style="margin-bottom:0; flex: 1; padding: 8px; font-size: 13px;">
            </div>
            <div style="display: flex; gap: 8px; margin-bottom: 8px;">
                <select id="memberGender" style="margin-bottom:0; flex: 1; padding: 8px; font-size: 13px;">
                    <option value="">Gender</option>
                    <option value="Male">Male</option>
                    <option value="Female">Female</option>
                    <option value="Other">Other</option>
                </select>
                <select id="memberRelation" style="margin-bottom:0; flex: 1; padding: 8px; font-size: 13px;">
                    <option value="">Relation</option>
                    <option value="Spouse">Spouse</option>
                    <option value="Son">Son</option>
                    <option value="Daughter">Daughter</option>
                    <option value="Mother">Mother</option>
                    <option value="Father">Father</option>
                    <option value="Other">Other</option>
                </select>
            </div>
            <button type="button" id="addMemberBtn" class="btn btn-secondary" style="width:100%; background:rgba(255,255,255,0.2); padding: 8px; font-size:12px; color: white; border: none; border-radius: 5px;">➕ Add Member</button>
        </div>

        <div style="display: flex; gap: 10px; margin-top: 10px; width: 100%;">
          <button id="prevStepBtn" class="btn btn-secondary" style="flex: 1; background: rgba(255,255,255,0.2); color: white;">⬅ Back</button>
          <button id="saveDraftBtn" class="btn btn-secondary" style="flex: 1; background: #ffcc00; color: #333;">💾 Save Draft</button>
        </div>
        <button id="saveFamilyBtn" class="btn btn-primary" style="margin-top: 15px; width: 100%;">🚀 Register Family</button>
    </div>
</div>

<script src="./js/db.js"></script>
<script src="./js/sync.js"></script>
<script src="./js/ocr-processor.js"></script>
<script src="worker.js"></script>
<script src="./js/status-banner.js"></script>

<!-- OCR Canvas and Modal elements -->
<canvas id="ocrPreprocessCanvas" style="display: none;"></canvas>

<!-- OCR VALIDATION MODAL -->
<div id="ocrValidationModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.6); z-index: 10000; align-items: center; justify-content: center; backdrop-filter: blur(5px);">
  <div style="background: #ffffff; color: #333333; width: 480px; max-width: 90%; border-radius: 15px; padding: 25px; box-shadow: 0 10px 30px rgba(0,0,0,0.3); text-align: left; max-height: 90vh; overflow-y: auto;">
    <h3 style="margin-top: 0; color: #ff1675; font-size: 20px; border-bottom: 2px solid #ffd6eb; padding-bottom: 10px; display: flex; align-items: center; justify-content: space-between;">
      <span>🛡️ Review Aadhaar Details</span>
      <span style="font-size: 12px; font-weight: normal; background: #ffd6eb; color: #ff1675; padding: 3px 8px; border-radius: 10px;" id="overallAccuracy">Accuracy: --</span>
    </h3>
    <p style="font-size: 12px; color: #666; margin-top: 5px; margin-bottom: 20px;">Please check the extracted fields below and correct any minor errors before saving.</p>
    
    <!-- Editable Fields with Confidence badges -->
    <div style="margin-bottom: 15px;">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 5px;">
        <label style="font-size: 13px; font-weight: bold; color: #555;">Family Head Name *</label>
        <span id="nameConfBadge" style="font-size: 11px; font-weight: bold; padding: 2px 6px; border-radius: 4px;"></span>
      </div>
      <input type="text" id="modalHeadName" style="margin-bottom: 0; border: 1px solid #ccc; padding: 8px; color: #333; width: 100%; box-sizing: border-box; background: #fafafa;">
    </div>

    <div style="margin-bottom: 15px;">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 5px;">
        <label style="font-size: 13px; font-weight: bold; color: #555;">Aadhaar Number *</label>
        <span id="aadhaarConfBadge" style="font-size: 11px; font-weight: bold; padding: 2px 6px; border-radius: 4px;"></span>
      </div>
      <input type="text" id="modalAadhaar" placeholder="XXXX XXXX XXXX" style="margin-bottom: 0; border: 1px solid #ccc; padding: 8px; color: #333; width: 100%; box-sizing: border-box; background: #fafafa;">
    </div>

    <div style="display: flex; gap: 15px; margin-bottom: 15px;">
      <div style="flex: 1;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 5px;">
          <label style="font-size: 13px; font-weight: bold; color: #555;">Date of Birth *</label>
          <span id="dobConfBadge" style="font-size: 11px; font-weight: bold; padding: 2px 6px; border-radius: 4px;"></span>
        </div>
        <input type="text" id="modalDob" placeholder="DD/MM/YYYY" style="margin-bottom: 0; border: 1px solid #ccc; padding: 8px; color: #333; width: 100%; box-sizing: border-box; background: #fafafa;">
      </div>
      <div style="flex: 1;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 5px;">
          <label style="font-size: 13px; font-weight: bold; color: #555;">Gender *</label>
          <span id="genderConfBadge" style="font-size: 11px; font-weight: bold; padding: 2px 6px; border-radius: 4px;"></span>
        </div>
        <select id="modalGender" style="margin-bottom: 0; border: 1px solid #ccc; padding: 8px; color: #333; width: 100%; box-sizing: border-box; background: #fafafa; height: 37px;">
          <option value="">Select Gender</option>
          <option value="Male">Male</option>
          <option value="Female">Female</option>
          <option value="Other">Other</option>
        </select>
      </div>
    </div>

    <div style="margin-bottom: 15px;">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 5px;">
        <label style="font-size: 13px; font-weight: bold; color: #555;">Address *</label>
        <span id="addressConfBadge" style="font-size: 11px; font-weight: bold; padding: 2px 6px; border-radius: 4px;"></span>
      </div>
      <input type="text" id="modalAddress" style="margin-bottom: 0; border: 1px solid #ccc; padding: 8px; color: #333; width: 100%; box-sizing: border-box; background: #fafafa;">
    </div>

    <div style="margin-bottom: 25px;">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 5px;">
        <label style="font-size: 13px; font-weight: bold; color: #555;">PIN Code *</label>
        <span id="pinConfBadge" style="font-size: 11px; font-weight: bold; padding: 2px 6px; border-radius: 4px;"></span>
      </div>
      <input type="text" id="modalPin" placeholder="6-digit PIN" style="margin-bottom: 0; border: 1px solid #ccc; padding: 8px; color: #333; width: 100%; box-sizing: border-box; background: #fafafa;">
    </div>

    <!-- Buttons Stack -->
    <div style="display: flex; flex-direction: column; gap: 8px;">
      <button type="button" id="modalConfirmBtn" class="btn" style="margin: 0; width: 100%; background: #ff1675; color: white; padding: 12px; font-weight: bold; border-radius: 30px; border: none; cursor: pointer;">Confirm & Autofill</button>
      
      <div style="display: flex; gap: 8px;">
        <button type="button" id="modalRetakeBtn" class="btn" style="margin: 0; flex: 1; background: #2c7be5; color: white; padding: 10px; font-size: 13px; border-radius: 30px; border: none; cursor: pointer;">📷 Retake Photo</button>
        <button type="button" id="modalManualBtn" class="btn" style="margin: 0; flex: 1; background: #6c757d; color: white; padding: 10px; font-size: 13px; border-radius: 30px; border: none; cursor: pointer;">✍️ Manual Entry</button>
      </div>
    </div>
  </div>
</div>

</body>
</html>
