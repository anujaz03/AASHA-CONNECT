<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="worker.css">
    <title>Family Records</title>
    <link rel="icon" href="/favicon.ico" />

</head>
<body>

<div class="navbar">
    <div class="logo">AASHA Connect</div>

    <nav>
        <a href="dashboard.html">Dashboard</a>
        <a href="add-family.html">Add Family</a>
        <a href="families.html">Families</a>
        <a href="qr.html">Scan QR</a>
        <a href="login.html" class="logout">Logout</a>
    </nav>
</div>

<div class="center-box">
   <h2>Saved Families</h2>
   <div class="stats-bar">
  <span id="onlineCount">🟢 Online: 0</span>
  <span id="offlineCount">🟡 Offline: 0</span>
</div>


<input
  type="text"
  id="searchBox"
  placeholder="🔍 Search by name or area"
  class="search-input"
/>

<button class="btn btn-primary" id="syncBtn">
  🔄 Sync Pending Data
</button>


    <div id="onlineFamilies" class="family-section">
    <h3>🟢 Synced Families (Online)</h3>
    <div class="family-list"></div>
</div>

<div id="offlineFamilies" class="family-section">
    <h3>🟡 Pending Sync (Offline)</h3>
    <div class="family-list"></div>
</div>


    <button class="btn btn-secondary" onclick="location.href='add-family.html'">
        ➕ Add New Family
    </button>
</div>


<script src="/worker/js/db.js"></script>
<script src="/worker/js/families.js"></script>


</body>
</html>